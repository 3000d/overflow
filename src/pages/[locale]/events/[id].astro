---
import {getCollection, render, getEntries} from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import OverviewCycleLayout from '../../../layouts/OverviewCycleLayout.astro';
import Button from '../../../components/Button.astro';
import Hero from '../../../components/Hero.astro';
import LongFormContent from '../../../components/LongFormContent.astro';
import {displayDateTimeSchedule} from '../../../utils';
import EventList from "../../../components/EventList.astro";

export async function getStaticPaths() {
    const posts = await getCollection('events');
    return posts.map((event) => {
        const locale = event.id.split('/')[0];
        event.id = event.id.replace(`${locale}/`, '');

        return ({
            params: {id: event.id, locale},
            props: {event},
        });
    });
}

const {event} = Astro.props;
const programme = event.data.programme ? await getEntries(event.data.programme) : null;
// todo : find a more generic way to configure custom layouts from markdown files, instead of hardcoding the overview cycle one here
const isOverviewCycle = event.id === 'overview-2';
const showHydraBanner = event.data.cycle && event.data.cycle === 'overview';
const {Content} = await render(event);

---

<style lang="scss">
  @use '../../../styles/mq';

  .event-container {
    position: relative;

    @include mq.tablet {
      margin-top: var(--spacing-xl);
    }
  }

  .ticket-cta {
    @include mq.desktop {
      display: none;
    }
  }

  .event-content {
    padding: var(--spacing-m) 0;

    @include mq.desktop {
      width: 50%;
    }
  }

  .event-content-container {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-l);
    margin-top: var(--spacing-l);

    @include mq.desktop {
      margin-top: var(--spacing-2xl);
      flex-direction: row;
    }
  }

  .event-ticket {
    background-color: var(--color-bg-base);
    padding: var(--spacing-m);
    max-width: 40em;

    @include mq.desktop {
      width: 50%;
    }
  }
</style>

{isOverviewCycle ? (
  <OverviewCycleLayout event={event} programme={programme ?? []} />
) : (
  <BaseLayout pageTitle={event.data.title} pageCover={event.data.cover} pageDescription={event.data.artists?.join(' / ')}>
    <section class="event-container with-spacing">
        <Hero
                title={event.data.title}
                above={displayDateTimeSchedule(event.data.startDate, event.data.endDate, event.data.schedule, Astro.currentLocale)}
                below={event.data.artists?.join(' / ')}
                bg={event.data.cover}
                hydraBanner={showHydraBanner}
        />

        <div class="event-content-container">
            <div class="event-content copy">
                <LongFormContent>
                    {event.data.ticket && event.data.embedTicketForm && (
                            <Button class="ticket-cta" href="#pretix-event-widget">Tickets ↓</Button>
                    )}
                    <Content/>
                </LongFormContent>
            </div>
            {
                event.data.ticket && (
                            <div class="event-ticket">
                                {event.data.embedTicketForm ? (
                                        <pretix-widget id="pretix-event-widget" event={event.data.ticket} single-item-select="button"></pretix-widget>
                                        <noscript>
                                            <Button href={event.data.ticket} title="Buy tickets online" large full
                                                    target="_blank">
                                                {event.data.free === true ? 'Free' : ''}
                                                Tickets ↗
                                            </Button>
                                        </noscript>
                                ) : (
                                        <Button href={event.data.ticket} title="Buy tickets online" large full target="_blank">
                                            {event.data.free === true ? 'Free' : ''}
                                            Tickets ↗
                                        </Button>
                                )}
                            </div>
                )
            }
        </div>
    </section>
    {programme?.length &&
            <EventList
                    title="Programme"
                    intro={event.data.programmeIntro}
                    events={programme}
            />}
  </BaseLayout>
)}
