---
import type { CollectionEntry } from 'astro:content';
import { getLocaleCollectionUrl } from '@i18n/utils';

interface Props {
  programme: CollectionEntry<'events'>[];
}

const { programme } = Astro.props;

const sessionsSorted = [...programme].sort(
  (a, b) => a.data.startDate.getTime() - b.data.startDate.getTime(),
);

const currentLocale = Astro.currentLocale ?? 'en';
const formatDate = (d: Date) =>
  d.toLocaleDateString(currentLocale, { day: 'numeric', month: 'short' });
---

<style>
  .marquee-ticker {
    position: relative;
    overflow: hidden;
    margin-top: 1rem;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(6px);
    padding: 0.5rem 0;
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee-scroll 40s linear infinite;
  }

  .marquee-item {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    white-space: nowrap;
    color: var(--color-text-accent);
    font-size: var(--typography-fontsize-l);
    font-weight: 300;
    letter-spacing: 0.08em;
  }

  .marquee-item + .marquee-item::before {
    content: '✦';
    color: var(--color-text-base);
    margin: 0 3rem;
  }

  .marquee-date {
    color: var(--color-text-accent);
    text-transform: uppercase;
  }

  .marquee-time {
    color: var(--color-text-accent);
  }

  .marquee-artist {
    color: var(--color-text-base);
    font-weight: 500;
    text-decoration: none;
  }

  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
</style>

<section>
  <div class="marquee-ticker">
    <div class="marquee-track">
      {
        [...sessionsSorted, ...sessionsSorted].map((s) => (
          <span class="marquee-item">
            <span class="marquee-date">░ {formatDate(s.data.startDate)} ░</span>
            <span class="marquee-time">{s.data.schedule} ░</span>
            <span class="marquee-sep" />
            <a
              href={getLocaleCollectionUrl(currentLocale, 'events', s.id)}
              class="marquee-artist"
            >
              {s.data.title}
            </a>
          </span>
        ))
      }
    </div>
  </div>
</section>
