---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import SectionTitle from './SectionTitle.astro';
import { displayDateTimeSchedule } from '../utils';
import { getLocaleCollectionUrl } from '../i18n/utils';
import { toZonedTime } from 'date-fns-tz';

interface Props {
  events: CollectionEntry<'events'>[];
  title?: string;
  fallback?: string;
  intro?: string;
  size?: 'medium' | 'small';
}

const { events, title, fallback, intro, size } = Astro.props;
const getEventLink = (id: string) =>
  getLocaleCollectionUrl(Astro.currentLocale, 'events', id);
---

<style lang="scss">
  @use '../styles/mq';

  .event-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xl);

    @include mq.tablet {
      gap: var(--spacing-l);
    }
  }

  .event {
    display: flex;
    flex-direction: column-reverse;
    justify-content: space-between;
    position: relative;
    text-transform: uppercase;
    letter-spacing: 0.1em;

    @include mq.tablet {
      height: 320px;
      flex-direction: row;
      gap: var(--spacing-l);
      padding-right: 0;
    }
  }

  .event-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-s);
    margin-top: var(--spacing-m);

    @include mq.tablet {
      gap: var(--spacing-m);
      margin-top: 0;
      width: 50%;
    }

    @include mq.desktop {
      width: 60%;
    }
  }

  .event-date {
    color: var(--color-text-accent);

    @include mq.desktop {
      font-size: var(--typography-fontsize-l);
    }
  }

  .event-title {
    font-weight: 400;
    line-height: 1.1;
    font-size: var(--typography-fontsize-l);

    @include mq.desktop {
      font-size: var(--typography-fontsize-xl);
    }

    a {
      color: var(--color-text-base);
      text-decoration: none;
    }
  }

  .event-cover {
    overflow: hidden;

    @include mq.tablet {
      width: 50%;
    }

    @include mq.desktop {
      width: 40%;
    }

    a {
      display: block;
      height: 100%;
    }

    img {
      height: 100%;
      width: 100%;
      object-fit: cover;
    }
  }

  .event-type {
    position: absolute;
    top: var(--spacing-m);
    right: var(--spacing-m);
    background-color: var(--color-bg-accent);
    color: var(--color-text-inverse);
    padding: 0 var(--spacing-2xs);
    pointer-events: none;
  }

  .--small {
    gap: var(--spacing-m, 0);

    .event {
      height: inherit;
    }

    .event-content {
      display: inline;
      width: 100%;
    }

    .event-date {
      display: inline;
      font-size: var(--typography-fontsize-m);

      @include mq.tablet {
        font-size: var(--typography-fontsize-l);
      }
    }

    .event-title {
      display: inline;
      font-size: var(--typography-fontsize-m);

      @include mq.tablet {
        font-size: var(--typography-fontsize-l);
      }
    }
  }
</style>

<section class:list={['event-list', { '--small': size === 'small' }]}>
  {title && <SectionTitle>{title}</SectionTitle>}

  {
    intro && (
      <div class="long-form-content">
        <p class="with-spacing-left">{intro}</p>
      </div>
    )
  }

  {
    events?.map((event) => (
      <div class="event with-spacing">
        <div class="event-content">
          <p class="event-date">
            {size !== 'small'
              ? displayDateTimeSchedule(
                  event.data.startDate,
                  event.data.endDate,
                  event.data.schedule,
                  Astro.currentLocale,
                )
              : toZonedTime(
                  event.data.startDate,
                  'Europe/Brussels',
                ).toLocaleDateString(Astro.currentLocale, {
                  day: 'numeric',
                  month: 'numeric',
                  year: 'numeric',
                })}
          </p>
          <h4 class="event-title">
            <a href={getEventLink(event.id)}>{event.data.title}</a>
          </h4>
          {size !== 'small' && <p>{event.data.artists?.join(' / ')}</p>}
        </div>

        {event.data.cover && size !== 'small' && (
          <p class="event-cover">
            <a href={getEventLink(event.id)}>
              <Image src={event.data.cover} format="avif" alt="" height="350" />
            </a>
          </p>
        )}

        {event.data.type && size !== 'small' && (
          <span class="event-type">{event.data.type}</span>
        )}
      </div>
    ))
  }

  {
    !events.length && fallback && (
      <p class="fallback with-spacing-left">{fallback}</p>
    )
  }
</section>
