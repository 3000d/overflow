---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { getLocaleCollectionUrl } from '@i18n/utils';

interface Props {
  event: CollectionEntry<'events'>;
  programme: CollectionEntry<'events'>[];
}

const { event, programme } = Astro.props;

const sessionsSorted = [...programme].sort(
  (a, b) => a.data.startDate.getTime() - b.data.startDate.getTime()
);

const currentLocale = Astro.currentLocale ?? 'en';
const formatDate = (d: Date) =>
  d.toLocaleDateString(currentLocale, { day: 'numeric', month: 'short' });
---

<BaseLayout pageTitle={event.data.title} pageCover={null}>
  <div id="hydra-wrap">
    <canvas id="hydra-canvas"></canvas>
    <div id="marquee-ticker">
      <div id="marquee-track">
        {[...sessionsSorted, ...sessionsSorted].map((s) => (
          <span class="marquee-item">
          <span class="marquee-date">{formatDate(s.data.startDate)}</span>
            <span class="marquee-time">{s.data.schedule}</span>
            <span class="marquee-sep">—</span>
          <a  href={getLocaleCollectionUrl(currentLocale, 'events', s.id)}>
            <span class="marquee-artist">{s.data.title}</span>
          </a>
          </span>
        ))}
      </div>
    </div>
  </div>
  
  <script>
    import Hydra from 'hydra-synth';
    import {textmode} from 'textmode.js';
    const canvas = document.getElementById('hydra-canvas');
    const hydra = new Hydra({ detectAudio: false, canvas });
    hydra.setResolution(window.innerWidth, 300);

    const tm = textmode.create({ canvas, overlay: true });
    tm.setup(() => {
      tm.fontSize(22);
      tm.overlay
        .characters('.÷ôÇ€')
        .cellColorMode('fixed')
        .cellColor(0, 0, 0)
        .charColorMode('sampled')
        .background(0, 0, 0, 255);
    });
    tm.draw(() => {
      tm.background(0);
      tm.image(tm.overlay, tm.grid.cols, tm.grid.rows);
    });

    osc(9, 0.05, 0.2)
      .color(1, 0, 1)
      .rotate(() => (hydra.synth.mouse.x / hydra.synth.width) * Math.PI * 0.5)
      .modulateRotate(osc(3, 0.1), 1)
      .add(src(o1).scale(1.5, 1.1), 0.9)
      .out(o0);
    shape(4, 0.3, 0.2).color(1, 1, 0).out(o1);
  </script>
</BaseLayout>

<style>
  #hydra-wrap {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  #hydra-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  #marquee-ticker {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    z-index: 10;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(6px);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    padding: 1rem 0;
    pointer-events: auto;
  }

  #marquee-track {
    display: flex;
    width: max-content;
    animation: marquee-scroll 60s linear infinite;
  }

  .marquee-item {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0 3rem;
    white-space: nowrap;
    color: var(--color-text-accent);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 300;
    letter-spacing: 0.08em;
  }

  .marquee-item + .marquee-item::before {
    content: '✦';
    margin-right: 3rem;
    opacity: 0.3;
    font-size: 0.6em;
  }

  .marquee-date {
    color: #fff;
    font-weight: 700;
    text-transform: uppercase;
  }

  .marquee-time {
    color: #fff;
    font-size: 0.85em;
  }

  .marquee-sep {
    opacity: 0.3;
  }

  .marquee-artist {
    font-style: italic;
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
